{
  "name": "@cardor/agent-harness-kit",
  "version": "0.16.0",
  "description": "CLI scaffolding for multi-agent harness systems",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ahk": "./bin/ahk.js"
  },
  "scripts": {
    "build": "npm run build:ui && tsup && npm run copy-assets",
    "build:ui": "cd dashboard && npm install --prefer-offline && npm run build",
    "copy-assets": "node scripts/copy-assets.mjs",
    "dev": "tsup --watch",
    "test": "node --test --import tsx/esm src/tests/*.test.ts",
    "lint": "eslint . --fix",
    "prepublishOnly": "npm run build && npm test",
    "prepare": "husky"
  },
  "files": [
    "bin",
    "dist"
  ],
  "keywords": [
    "agents",
    "ai",
    "harness",
    "claude",
    "mcp",
    "scaffolding"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "jiti": "^2.4.2",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cardor/agent-harness-kit": "^0.16.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint-react/eslint-plugin": "^5.7.1",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
